{
  "name": "pkc2",
  "version": "2.0.0",
  "private": true,
  "description": "Portable Knowledge Container - Generation 2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:bundle": "vite build",
    "build:release": "tsx build/release-builder.ts",
    "build": "npm run build:bundle && npm run build:release",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "happy-dom": "^20.8.9",
    "terser": "^5.30.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
